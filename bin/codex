#!/usr/bin/env bash
set -euo pipefail

canonical_path() {
  local path="$1"
  if command -v realpath >/dev/null 2>&1; then
    realpath "$path"
  elif readlink -f "$path" >/dev/null 2>&1; then
    readlink -f "$path"
  else
    local dir base
    dir="$(cd "$(dirname "$path")" && pwd -P)"
    base="$(basename "$path")"
    printf '%s/%s\n' "$dir" "$base"
  fi
}

find_project_profile_file() {
  local dir="$PWD"
  while :; do
    if [[ -f "$dir/.codex-as-profile" ]]; then
      printf '%s/.codex-as-profile\n' "$dir"
      return 0
    fi
    [[ "$dir" == "/" ]] && return 1
    dir="$(dirname "$dir")"
  done
}

read_project_profile() {
  sed -n '
    /^[[:space:]]*#/d
    /^[[:space:]]*$/d
    s/^[[:space:]]*//
    s/[[:space:]]*$//
    p
    q
  ' "$1"
}

self="$(canonical_path "$0")"

real_codex="$(
  type -a -P codex \
    | while read -r path; do
        if [[ "$(canonical_path "$path")" != "$self" ]]; then
          printf '%s\n' "$path"
          break
        fi
      done
)"

if [[ -z "${real_codex:-}" ]]; then
  echo "error: original codex not found after wrapper in PATH" >&2
  exit 127
fi

if ! command -v codex-as >/dev/null 2>&1; then
  echo "error: codex-as not found in PATH; install codex-as next to the codex wrapper" >&2
  exit 127
fi

project_profile_file="$(find_project_profile_file || true)"
if [[ -n "$project_profile_file" ]]; then
  project_profile="$(read_project_profile "$project_profile_file")"
  if [[ -z "$project_profile" ]]; then
    echo "error: empty project profile file: $project_profile_file" >&2
    exit 2
  fi
  exec codex-as "$project_profile" --codex-bin "$real_codex" -- "$@"
fi

if ! codex-as current >/dev/null 2>&1; then
  exec "$real_codex" "$@"
fi

exec codex-as run --codex-bin "$real_codex" -- "$@"
